---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectList from '../../components/ProjectList.astro';
import { projects } from './projects';
---

<BaseLayout title='All Projects' description='All my project portfolio from real projects to open source projects.'>
	<div class='container'>
		<div class='mb-16 md:mb-20 max-w-3xl'>
			<h1 class='text-2xl md:text-3xl font-semibold mb-4 font-serif text-earth-900 dark:text-earth-100'>Projects</h1>
			<p class='text-base text-earth-700 dark:text-earth-300 leading-relaxed'>
				My most recently updated projects, pulled live from GitHub. A mix of personal experiments, tools I built to scratch my own itch, and open-source contributions.
			</p>
		</div>
		<ProjectList projects={projects} />
	</div>
</BaseLayout>
