---
import { Image } from 'astro:assets';
import type { Project } from '../pages/projects/projects';
import { kFormatter } from '../utils';
import GithubWhite from '@src/assets/img/github-mark-white.svg';
import GithubBlack from '@src/assets/img/github-mark.svg';

const { projects } = Astro.props;
---

<div class='grid grid-cols-12 gap-5'>
	{
		projects.map((project: Project) => (
			<div class='group col-span-12 sm:col-span-6 lg:col-span-4 glass rounded-xl transition-colors duration-200 py-6 px-6 flex flex-col gap-4 hover:bg-earth-50/30 dark:hover:bg-earth-900/20'>
				<div class='flex justify-between items-start gap-4'>
					<h3 class='font-bold text-lg text-earth-900 dark:text-earth-100 leading-snug group-hover:text-earth-700 dark:group-hover:text-earth-200 transition-colors'>
						<a
							class='hover:underline decoration-2 underline-offset-4 decoration-earth-300 dark:decoration-earth-600'
							href={project.html_url}
							target='_blank'>
							{project.name}
						</a>
					</h3>
					{project.stargazers_count !== undefined && (
						<a
							href={project.html_url}
							target='_blank'
							class='shrink-0 flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs text-earth-600 dark:text-earth-300 bg-earth-100/80 dark:bg-earth-800/60 hover:bg-earth-200 dark:hover:bg-earth-700 transition-colors font-display'>
							<Image src={GithubBlack} height={14} class='dark:hidden' alt='GitHub' />
							<Image src={GithubWhite} height={14} class='hidden dark:block' alt='GitHub' />
							<span class='font-semibold'>{kFormatter(project.stargazers_count)}</span>
						</a>
					)}
				</div>
				<p class='text-sm text-earth-600 dark:text-earth-300 line-clamp-2 leading-relaxed flex-grow'>
					{project.description}
				</p>
				{(project.topics || []).length > 0 && (
					<div class='flex flex-wrap gap-1.5 mt-auto pt-2'>
						{(project.topics || []).slice(0, 4).map((tag: string) => (
							<span class='inline-block px-2.5 py-1 rounded-md text-xs font-medium text-earth-500 dark:text-earth-400 bg-earth-100/60 dark:bg-earth-800/40 hover:bg-earth-200/70 dark:hover:bg-earth-700/60 transition-colors'>
								{tag}
							</span>
						))}
						{(project.topics || []).length > 4 && (
							<span class='inline-block px-2.5 py-1 rounded-md text-xs font-medium text-earth-400 dark:text-earth-500 bg-earth-50/60 dark:bg-earth-900/40'>
								+{(project.topics || []).length - 4}
							</span>
						)}
					</div>
				)}
			</div>
		))
	}
</div>
